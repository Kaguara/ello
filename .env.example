# Which speech adapter the client should use. Boots fine with none set.
# webspeech (default, zero-config) | elevenlabs | azure
VOICE_ADAPTER=webspeech

# --- elevenlabs adapter (TTS upgrade) ---
# Get from https://elevenlabs.io -> Profile -> API Keys
ELEVENLABS_API_KEY=
# Get from https://elevenlabs.io -> Voice Library, pick a voice, copy its Voice ID
ELEVENLABS_VOICE_ID=

# --- azure adapter (pronunciation scoring) ---
# Get from https://portal.azure.com -> create "Speech" resource -> Keys and Endpoint
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Set automatically by Railway; only needed for local overrides.
PORT=8080
